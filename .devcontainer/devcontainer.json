{
    "name": "Node.js",
    "image": "mcr.microsoft.com/devcontainers/javascript-node:1-20-bullseye",
    "customizations": {
        "vscode": {
            "settings": {},
            "extensions": [
                "dbaeumer.vscode-eslint"
            ]
        }
    },
    "forwardPorts": [
        3000
    ],
    "postCreateCommand": "npm install",
    "portsAttributes": {
        "3000": {
            "label": "Application",
            "onAutoForward": "notify"
        }
    }
}